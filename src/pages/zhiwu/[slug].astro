---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';

export async function getStaticPaths() {
	const plants = await getCollection('plants', ({ data }) => !data.draft);
	return plants.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, photos, date, location, tags, summary } = entry.data;
const desc = summary ?? `抱财丘徒步观察：${title}`;
---

<BaseLayout title={title} description={desc}>
	<article class="container article">
		<nav class="breadcrumb" aria-label="面包屑导航">
			<a href="/tujian">植物图鉴</a>
			<span class="breadcrumb__sep" aria-hidden="true">/</span>
			<span class="breadcrumb__current">{title}</span>
		</nav>

		<div class="article__body">
			{
				photos.length > 0 && (
					<div class="gallery" aria-label="植物照片">
						{photos.map((src, i) => {
							const detail = src.endsWith('.webp') ? src.replace(/\.webp$/, '_detail.webp') : src;
							return (
								<figure class="gallery__item">
									<img src={detail} alt={`${title}的照片 ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} width="900" height="675" />
								</figure>
							);
						})}
					</div>
				)
			}

			<div class="article__right">
				<header class="article__head">
					<h1 class="article__title">{title}</h1>
					<div class="article__meta">
						{
							date && (
								<span>
									观察日期：
									<time datetime={date.toISOString()}>
										{date.toLocaleDateString('zh-CN', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</time>
								</span>
							)
						}
						{location && <span>地点：{location}</span>}
					</div>
					{
						tags.length > 0 && (
							<div class="article__tags">
								{tags.map((t) => (
									<span class="tag">{t}</span>
								))}
							</div>
						)
					}
				</header>

				<div class="prose">
					<Content />
				</div>

				<p class="back">
					<a class="btn" href="/tujian">返回图鉴</a>
				</p>
			</div>
		</div>

		<Disclaimer />
	</article>
</BaseLayout>

<style>
	.article {
		padding: var(--space-lg) 0 0;
	}

	.breadcrumb {
		font-size: 0.95rem;
		margin-bottom: var(--space-md);
		color: var(--color-midnight-teal);
	}

	.breadcrumb a {
		text-decoration: none;
	}

	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.breadcrumb__sep {
		margin: 0 0.35rem;
		opacity: 0.7;
	}

	.breadcrumb__current {
		color: var(--color-body);
	}

	/* PC 双栏：左图右文 */
	.article__body {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: start;
		margin-bottom: var(--space-lg);
	}

	@media (max-width: 800px) {
		.article__body {
			grid-template-columns: 1fr;
			gap: var(--space-lg);
		}
	}

	.article__right {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.article__head {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.article__title {
		margin: 0;
		font-size: clamp(1.6rem, 2.8vw, 2.1rem);
		line-height: 1.3;
	}

	.article__meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs) var(--space-md);
		font-size: 0.95rem;
		color: var(--color-body);
		opacity: 0.8;
	}

	.article__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}

	/* 图片栏：单张时铺满，多张时竖向堆叠 */
	.gallery {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		position: sticky;
		top: calc(var(--site-header-height) + var(--space-md));
	}

	/* 移动端单栏：图片取消 sticky，随页面正常滚动 */
	@media (max-width: 800px) {
		.gallery {
			position: static;
		}
	}

	.gallery__item {
		margin: 0;
		border-radius: var(--radius);
		overflow: hidden;
		border: 1px solid rgba(16, 86, 102, 0.12);
		box-shadow: var(--shadow-soft);
		background: rgba(131, 153, 88, 0.08);
	}

	.gallery__item img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		display: block;
	}

	/* 正文 */
	.prose {
		font-size: 1.02rem;
		line-height: 1.85;
		color: var(--color-body);
	}

	.prose :global(h2) {
		font-size: 1.15rem;
		margin: var(--space-lg) 0 var(--space-sm);
		color: var(--color-midnight-teal);
	}

	.prose :global(h2:first-child) {
		margin-top: 0;
	}

	.prose :global(p) {
		margin: 0 0 var(--space-md);
	}

	.prose :global(ol),
	.prose :global(ul) {
		margin: 0 0 var(--space-md);
		padding-left: 1.4rem;
	}

	.prose :global(li) {
		margin-bottom: var(--space-xs);
	}

	.prose :global(blockquote) {
		margin: var(--space-md) 0;
		padding: var(--space-sm) var(--space-md);
		border-left: 3px solid rgba(131, 153, 88, 0.5);
		background: rgba(131, 153, 88, 0.06);
		border-radius: 0 var(--radius) var(--radius) 0;
		font-size: 0.97rem;
		color: var(--color-body);
	}

	.prose :global(blockquote p) {
		margin: 0;
	}

	.back {
		margin: 0;
	}
</style>
